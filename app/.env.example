# =============================================================================
# Public - exposed to the browser.
# =============================================================================

# Sui network the dApp targets. "localnet" | "testnet" | "mainnet".
# MVR-resolved deps (`@pas/pas`, the OpenZeppelin Move packages) are only
# published on testnet/mainnet; localnet uses test-publish.
NEXT_PUBLIC_SUI_NETWORK=testnet

# Optional per-deploy fullnode override for the active NETWORK. Useful when
# Mysten's public fullnode is down / rate-limiting (Suiscan, Blockvision,
# PublicNode all publish testnet endpoints). Falls back to `getFullnodeUrl`
# when unset. See sui-client.ts.
# NEXT_PUBLIC_SUI_RPC_URL=

# Enoki public API key. Used by the client-side zkLogin OAuth flow.
# Get one from https://portal.enoki.mystenlabs.com - must be the *public* key
# (prefix `enoki_public_...`). The matching *private* key lives below (server-only).
NEXT_PUBLIC_ENOKI_API_KEY=

# Google OAuth client ID (Web application type in Google Cloud Console).
# Used by Enoki's zkLogin flow. Only the client_id is needed; do NOT include
# the client_secret - zkLogin uses the implicit/PKCE OAuth flow.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Deployment IDs - written by `pnpm bootstrap` after `sui client publish`.
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_MERCHANT_ID=
NEXT_PUBLIC_ACCESS_CONTROL_ID=
NEXT_PUBLIC_LOYALTY_POLICY_ID=
NEXT_PUBLIC_STABLECOIN_PACKAGE_ID=
NEXT_PUBLIC_STABLECOIN_POLICY_ID=
# Shared `Currency<STABLECOIN_MOCK>` (post-finalize-registration). Required by
# `config::new<C>` to read decimals when the merchant edits config.
NEXT_PUBLIC_STABLECOIN_CURRENCY_ID=
NEXT_PUBLIC_STABLECOIN_TYPE=

# pas Namespace shared object id.
NEXT_PUBLIC_NAMESPACE_ID=

# pas package id - resolved from MVR (`@pas/pas`) on testnet/mainnet, or from
# the test-publish pubfile on localnet.
NEXT_PUBLIC_PAS_PACKAGE_ID=

# `openzeppelin_access` package - hosts `access_control::grant_role` /
# `new_auth`, which the merchant flows call. Resolved from MVR on testnet/
# mainnet, or from the test-publish pubfile on localnet.
NEXT_PUBLIC_OZ_ACCESS_PACKAGE_ID=

# Shared `pas::templates::Templates` - needed by stablecoin_mock setup.
# Bootstrap creates it on localnet and discovers it on testnet/mainnet.
NEXT_PUBLIC_TEMPLATES_ID=

# Deployer's Sui address (public, not the private key). Written by
# `pnpm bootstrap`. The client uses this to detect deployer-signed txs on
# localnet and skip the gas station for them - sponsoring your own tx
# collides with the wallet's own gas selection, so the deployer's own txs
# pay their own gas from their (bootstrap-funded) wallet balance.
NEXT_PUBLIC_DEPLOYER_ADDRESS=

# =============================================================================
# Server-only - never exposed to the browser.
# =============================================================================

# Enoki private key. Used by API route handlers to sponsor transactions
# (gasless UX) and, optionally, to mediate zkLogin proof creation server-side.
ENOKI_PRIVATE_API_KEY=

# Rate limits on the three server-signed routes. Each route has two
# independent buckets - per-identity AND per-IP - checked atomically so
# rotating either dimension still trips the other's cap. Shared in-memory
# backing (`lib/rate-limit.ts`) does NOT scale horizontally; swap for
# Redis/KV before shipping a public deploy. Defaults ship in code;
# uncomment to override.
#
# `/api/enoki-sponsor` - budget-drain defense on top of Enoki's dashboard
# `allowedMoveCallTargets` + budget cap. Defaults 60s / 10 per sender,
# 30 per IP.
# ENOKI_SPONSOR_RATE_WINDOW_MS=60000
# ENOKI_SPONSOR_RATE_MAX=10
# ENOKI_SPONSOR_IP_RATE_MAX=30
#
# `/api/sponsor` (localnet gas station) - defense-in-depth against
# accidental LAN exposure of the dev server. Defaults 60s / 30 per
# sender, 60 per IP.
# SPONSOR_RATE_WINDOW_MS=60000
# SPONSOR_RATE_MAX=30
# SPONSOR_IP_RATE_MAX=60
#
# `/api/topup` (mock-USD faucet) - throttles deployer testnet-SUI drain +
# bounds mock-USD minting. Defaults 60s / 3 per recipient, 10 per IP,
# per-request cap 1,000,000 USD (in 6-decimal base units).
# TOPUP_RATE_WINDOW_MS=60000
# TOPUP_RATE_MAX=3
# TOPUP_IP_RATE_MAX=10
# TOPUP_MAX_AMOUNT=1000000000000

# Deployer key (test-only). Used server-side for two things:
#   - `/api/topup` - sign the mock-USD faucet mint (holds TreasuryCap<STABLECOIN_MOCK>).
#   - `/api/sponsor` - pay gas for cashier + customer txs on localnet.
# Encode as a bech32 `suiprivkey...` string. Leave empty on mainnet.
DEPLOYER_PRIVATE_KEY=
