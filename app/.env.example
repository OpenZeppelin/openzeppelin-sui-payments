# =============================================================================
# Public — exposed to the browser.
# =============================================================================

# Sui network the dApp targets. One of: "devnet" | "testnet" | "mainnet" | "localnet".
NEXT_PUBLIC_SUI_NETWORK=testnet

# Enoki public API key. Used by the client-side zkLogin OAuth flow.
# Get one from https://portal.enoki.mystenlabs.com — must be the *public* key
# (prefix `enoki_public_...`). The matching *private* key lives below (server-only).
NEXT_PUBLIC_ENOKI_API_KEY=

# Google OAuth client ID (Web application type in Google Cloud Console).
# Used by Enoki's zkLogin flow. Only the client_id is needed; do NOT include
# the client_secret — zkLogin uses the implicit/PKCE OAuth flow.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Deployment IDs are written by `pnpm bootstrap` after `sui client publish`.
NEXT_PUBLIC_PACKAGE_ID=
NEXT_PUBLIC_MERCHANT_ID=
NEXT_PUBLIC_ACCESS_CONTROL_ID=
NEXT_PUBLIC_LOYALTY_POLICY_ID=
NEXT_PUBLIC_STABLECOIN_PACKAGE_ID=
NEXT_PUBLIC_STABLECOIN_POLICY_ID=
NEXT_PUBLIC_STABLECOIN_TYPE=

# Vendored PAS package + Namespace shared object.
NEXT_PUBLIC_PAS_PACKAGE_ID=
NEXT_PUBLIC_NAMESPACE_ID=

# =============================================================================
# Server-only — never exposed to the browser.
# =============================================================================

# Enoki private key. Used by API route handlers to sponsor transactions
# (gasless UX) and, optionally, to mediate zkLogin proof creation server-side.
ENOKI_PRIVATE_API_KEY=

# Deployer key (test-only). Used by the devnet/testnet faucet route to mint
# stablecoin into a customer's PAS account on top-up. Encode as a bech32
# `suiprivkey...` string. Leave empty on mainnet.
DEPLOYER_PRIVATE_KEY=

# Sponsor keypair used by /api/sponsor to pay gas on behalf of customers.
# Generate with `sui keytool generate ed25519 --json` (copy `secret_key`)
# and fund via `sui client faucet --address <addr>` on testnet.
SPONSOR_PRIVATE_KEY=
